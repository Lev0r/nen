rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/games/{gameId} {
      // The frontend strictly gates users, but backend defense requires you 
      // to replace these emails with your actual Google emails in production!
      allow read, write: if request.auth != null && (
        request.auth.token.email == 'kir.matienko@gmail.com' || 
        request.auth.token.email == 'xalex.yavorskiyx@gmail.com'
      );
    }
  }
}
